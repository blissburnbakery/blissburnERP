{
  "name": "blissburn-bakery-erp",
  "version": "1.0.0",
  "description": "Production ERP Backend and Database for Blissburn Bakery Products",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "prisma generate && prisma migrate deploy",
    "postinstall": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:backup": "pg_dump \"$DIRECT_URL\" -F c -f backups/blissburn_$(date +%F_%H%M).dump"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
